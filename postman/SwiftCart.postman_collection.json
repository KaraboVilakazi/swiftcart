{
  "info": {
    "name": "SwiftCart API",
    "description": "Complete SwiftCart e-commerce API collection.\n\nFlow: Register → Login → Browse Products → Add to Cart → Place Order\n\nThe JWT token is automatically saved after login and used in all authenticated requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8081",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"karabo@swiftcart.co.za\",\n  \"password\": \"Password1!\",\n  \"firstName\": \"Karabo\",\n  \"lastName\": \"Vilakazi\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "const token = pm.response.json().data.token;",
                  "pm.collectionVariables.set('token', token);",
                  "pm.test('Token saved', () => pm.expect(token).to.not.be.empty);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"karabo@swiftcart.co.za\",\n  \"password\": \"Password1!\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const token = pm.response.json().data.token;",
                  "pm.collectionVariables.set('token', token);",
                  "pm.test('Token saved', () => pm.expect(token).to.not.be.empty);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login as Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@swiftcart.co.za\",\n  \"password\": \"Admin@123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const token = pm.response.json().data.token;",
                  "pm.collectionVariables.set('token', token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/v1/users/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns email', () => pm.expect(pm.response.json().data.email).to.exist);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "List All Products",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/products"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns products', () => {",
                  "  const data = pm.response.json().data;",
                  "  pm.expect(data.content).to.be.an('array');",
                  "  pm.expect(data.totalElements).to.be.above(0);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/products/1"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns Samsung', () => pm.expect(pm.response.json().data.name).to.include('Samsung'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Search Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/search?q=samsung",
              "query": [{ "key": "q", "value": "samsung" }]
            }
          }
        },
        {
          "name": "Products by Category",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/products/category/6"
          }
        },
        {
          "name": "Create Product (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/v1/products",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sony WH-1000XM5\",\n  \"slug\": \"sony-wh-1000xm5\",\n  \"description\": \"Industry-leading noise cancelling headphones\",\n  \"price\": 5999.00,\n  \"categoryId\": 1,\n  \"initialStock\": 30\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Cart",
      "item": [
        {
          "name": "Get Cart",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/v1/cart"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Cart exists', () => pm.expect(pm.response.json().data.cartId).to.exist);"
                ]
              }
            }
          ]
        },
        {
          "name": "Add Samsung to Cart",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/cart/items?productId=1&quantity=1",
              "query": [
                { "key": "productId", "value": "1" },
                { "key": "quantity", "value": "1" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Item in cart', () => pm.expect(pm.response.json().data.itemCount).to.be.above(0));"
                ]
              }
            }
          ]
        },
        {
          "name": "Add Dell XPS to Cart",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/cart/items?productId=3&quantity=1",
              "query": [
                { "key": "productId", "value": "3" },
                { "key": "quantity", "value": "1" }
              ]
            }
          }
        },
        {
          "name": "Update Item Quantity",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/cart/items/1?quantity=2",
              "query": [{ "key": "quantity", "value": "2" }]
            }
          }
        },
        {
          "name": "Remove Item from Cart",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/v1/cart/items/3"
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Place Order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/v1/orders",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shippingAddress\": \"123 Sandton Drive, Sandton, Johannesburg, 2196\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Order confirmed', () => pm.expect(pm.response.json().data.status).to.equal('CONFIRMED'));",
                  "const orderId = pm.response.json().data.id;",
                  "pm.collectionVariables.set('orderId', orderId);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Order History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/v1/orders"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has orders', () => pm.expect(pm.response.json().data.content).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Order Detail",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/v1/orders/{{orderId}}"
          }
        }
      ]
    },
    {
      "name": "Inventory",
      "item": [
        {
          "name": "Get Stock Level",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/v1/inventory/1"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has quantity', () => pm.expect(pm.response.json().data.quantity).to.be.a('number'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Restock Product (Admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/inventory/1/restock?quantity=50",
              "query": [{ "key": "quantity", "value": "50" }]
            }
          }
        }
      ]
    }
  ]
}
